/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "alexmayhew-dev",
	// Account ID bypasses /memberships API call (fixes token auth issues)
	"account_id": "7a614aa1a5509b080b4e8cc556440e71",
	"main": "./custom-worker.ts",
	"compatibility_date": "2025-12-01",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"assets": {
		"binding": "ASSETS",
		"directory": ".open-next/assets",
	},
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES",
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "alexmayhew-dev",
		},
	],
	"observability": {
		"enabled": true,
	},
	/**
	 * Workers AI Binding
	 * Enables access to Cloudflare Workers AI models including Qwen 2.5-Coder 32B
	 */
	"ai": {
		"binding": "AI",
	},
	/**
	 * R2 Bucket for Incremental Cache
	 * Required for persistent ISR caching across deployments
	 * OpenNext expects binding name "NEXT_INC_CACHE_R2_BUCKET"
	 * Create bucket: wrangler r2 bucket create alexmayhew-dev-cache
	 */
	"r2_buckets": [
		{
			"binding": "NEXT_INC_CACHE_R2_BUCKET",
			"bucket_name": "alexmayhew-dev-cache",
		},
	],
	/**
	 * Rate Limiting — KV-based fallback
	 *
	 * The original `rate_limits` top-level key was rejected by Wrangler as an
	 * "Unexpected field". The 2026 `ratelimit` binding schema is also not yet
	 * recognized by Wrangler 4.80 (it warns "Unexpected fields found in
	 * top-level field: ratelimit" and suggests upgrading). Until we move to a
	 * Wrangler version that ships the `ratelimit` binding schema, use the KV
	 * namespace below as a fallback counter store.
	 *
	 * TODO: Once Wrangler supports the `ratelimit` binding (likely 4.90+),
	 * replace this `kv_namespaces` block with native `ratelimit` entries for
	 * RATE_LIMITER_CHAT, RATE_LIMITER_CONTACT, RATE_LIMITER_NEWSLETTER and
	 * update src/lib/rate-limit.ts to use `env.RATE_LIMITER_*.limit(...)`.
	 *
	 * TODO: Create the KV namespace before the first deploy of this change:
	 *   wrangler kv namespace create RATE_LIMIT_KV
	 * then paste the returned id into the `id` field below.
	 */
	"kv_namespaces": [
		{
			"binding": "RATE_LIMIT_KV",
			"id": "TODO_REPLACE_WITH_REAL_KV_NAMESPACE_ID",
		},
	],
	// Keep workers.dev subdomain active until custom domain is set up in dashboard
	"workers_dev": true,
	/**
	 * Smart Placement
	 * Automatically places Worker close to backend services for reduced latency
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/
	 */
	"placement": { "mode": "smart" },
	/**
	 * Environments
	 * Preview environment mirrors production bindings so Dependabot PR preview
	 * deploys don't fail with missing-binding errors. Uses a separate R2 bucket
	 * to isolate preview cache from production.
	 */
	"env": {
		"preview": {
			"name": "alexmayhew-dev-preview",
			"workers_dev": true,
			"compatibility_date": "2025-12-01",
			"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
			"assets": {
				"binding": "ASSETS",
				"directory": ".open-next/assets",
			},
			"images": {
				"binding": "IMAGES",
			},
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "alexmayhew-dev-preview",
				},
			],
			"observability": {
				"enabled": true,
			},
			"ai": {
				"binding": "AI",
			},
			"r2_buckets": [
				{
					"binding": "NEXT_INC_CACHE_R2_BUCKET",
					"bucket_name": "alexmayhew-dev-cache-preview",
				},
			],
			// TODO: migrate to `ratelimit` binding once Wrangler schema supports it.
			// For now, share the production KV fallback namespace — preview traffic
			// volume is too low to warrant a separate counter store.
			"kv_namespaces": [
				{
					"binding": "RATE_LIMIT_KV",
					"id": "TODO_REPLACE_WITH_REAL_KV_NAMESPACE_ID",
				},
			],
		},
	},
	/**
	 * Bindings
	 * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
	 * databases, object storage, AI inference, real-time communication and more.
	 * https://developers.cloudflare.com/workers/runtime-apis/bindings/
	 */
	/**
	 * Environment Variables
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
	 * Note: Use secrets to store sensitive data.
	 * https://developers.cloudflare.com/workers/configuration/secrets/
	 */
	// "vars": {  "MY_VARIABLE": "production_value" }
}
